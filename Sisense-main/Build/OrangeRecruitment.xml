<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Test Suite" parallel="false" thread-count="1" verbose="10">

	<listeners>
		<listener class-name="com.kfast.reports.CustomReporterBuildSummary" />
		<listener class-name="com.kfast.reports.CustomReporter" />
		<listener class-name="com.kfast.reports.ExtentReportListener" />
		<listener class-name="com.kfast.listeners.AnnotationTransformer" />
	</listeners>

	<!-- change this value to 'local' if email should be triggered from local-->
	<parameter name="env" value="jenkins" />
	
	<test name="Orange Recruitment Test">
		<classes>
			<class name="com.kfast.tests.OrangeRecruitmentTest">
				<methods>
					<include name="recruitmentFlow" />
				</methods>
			</class>
		</classes>
	</test>
</suite>