<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Test Suite" verbose="10">

	<listeners>
		<listener class-name="com.kfast.reports.CustomReporterBuildSummary" />
		<listener class-name="com.kfast.reports.CustomReporterForAPI" />
		<listener class-name="com.kfast.reports.ExtentReportListener" />
		<listener class-name="com.kfast.listeners.AnnotationTransformer" />
	</listeners>

	<!-- change this value to 'local' if email should be triggered from local-->
	<parameter name="env" value="jenkins" />

	
	
	<test name="Get User with POJO data from GraphQL API ">
		<classes>
			<class name="com.kfast.tests.GraphQLTests">
				<methods>
					<include name="getUsers_withPOJOTest" />
				</methods>
			</class>
		</classes>
	</test>
	
	
	<test name="Get User with more query variables from GraphQL API ">
		<classes>
			<class name="com.kfast.tests.GraphQLTests">
				<methods>
					<include name="getUsers_withQueryVariables" />
				</methods>
			</class>
		</classes>
	</test>
	
	<test name="Get Todos list with limit ">
		<classes>
			<class name="com.kfast.tests.GraphQLTests">
				<methods>
					<include name="getTodoswithLimitTest" />
				</methods>
			</class>
		</classes>
	</test>


</suite>