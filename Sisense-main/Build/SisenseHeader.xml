<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Header Pages" parallel="false" thread-count="1" verbose="10">

	<listeners>
		<listener class-name="com.kfast.reports.CustomReporterBuildSummary" />
		<listener class-name="com.kfast.reports.CustomReporter" />
		<listener class-name="com.kfast.reports.ExtentReportListener" />
		<listener class-name="com.kfast.listeners.AnnotationTransformer" />
	</listeners>

	<!-- change this value to 'local' if email should be triggered from local-->
	<parameter name="env" value="jenkins" />

	<test name="Sisense Header Testing">
		<classes>

			<class name="com.sisense.header.SisenseHeaderTest">
				<methods>
					<include name="verifySisenseHomePageTitle" />
					<include name="verifyPlatformPageTitleUnderHeaderSection" />
					<include name="verifySolutionsPageTitleUnderHeaderSection" />
					<include name="verifyDevelopersPageTitleUnderHeaderSection" />
					<include name="verifyResourcesPageTitleUnderHeaderSection" />
					<include name="verifyAboutPageTitleUnderHeaderSection" />
					<include name="verifyDemoPageTitleUnderHeaderSection" />
				</methods>
			</class>

		</classes>
	</test>
</suite>