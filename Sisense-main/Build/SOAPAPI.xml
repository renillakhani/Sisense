<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Test Suite" verbose="10">

	<listeners>
		<listener class-name="com.kfast.reports.CustomReporterBuildSummary" />
		<listener class-name="com.kfast.reports.CustomReporterForAPI" />
		<listener class-name="com.kfast.reports.ExtentReportListener" />
		<listener class-name="com.kfast.listeners.AnnotationTransformer" />
	</listeners>

	<!-- change this value to 'local' if email should be triggered from local-->
	<parameter name="env" value="jenkins" />

	<test name="Perform division operation">
		<classes>
			<class name="com.kfast.tests.RestAssured_SOAPTest">
				<methods>
					<include name="divTest" />
				</methods>
			</class>
		</classes>
	</test>
	<test name="Perform Multiplication operation">
		<classes>
			<class name="com.kfast.tests.RestAssured_SOAPTest">
				<methods>
					<include name="mulTest" />
				</methods>
			</class>
		</classes>
	</test>
	<test name="Perform Subtraction operation">
		<classes>
			<class name="com.kfast.tests.RestAssured_SOAPTest">
				<methods>
					<include name="subTest" />
				</methods>
			</class>
		</classes>
	</test>
	
</suite>